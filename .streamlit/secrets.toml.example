# Copy this file to `.streamlit/secrets.toml` for local dev, or paste these
# keys into Streamlit Community Cloud -> app Settings -> Secrets.
# DO NOT commit the real secrets.toml (it is gitignored).

# Supabase Postgres connection string. Use the *Transaction pooler* string from
# Supabase (Project -> Connect -> Transaction pooler), which supports IPv4 as
# required by Streamlit Cloud. Replace [PASSWORD] with your DB password.
DATABASE_URL = "postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Claude / Anthropic
ANTHROPIC_API_KEY = "sk-ant-..."

# LegiScan
LEGISCAN_API_KEY = "..."
