# Copy this file to `.streamlit/secrets.toml` for local dev, or paste these
# keys into Streamlit Community Cloud -> app Settings -> Secrets.
# DO NOT commit the real secrets.toml (it is gitignored).

# Supabase Postgres connection string. Use the *Transaction pooler* string from
# Supabase (Project -> Connect -> Transaction pooler), which supports IPv4 as
# required by Streamlit Cloud. Replace [PASSWORD] with your DB password.
DATABASE_URL = "postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# Claude / Anthropic
ANTHROPIC_API_KEY = "sk-ant-..."

# LegiScan
LEGISCAN_API_KEY = "..."

# ---------------------------------------------------------------------------
# SSO login (OPTIONAL). Add this [auth] block ONLY when you're ready to require
# sign-in. If it's absent, the app runs open (no login). When present, the app
# requires login and restricts access to @accela.com emails.
#
# Requires an OAuth app registered with your identity provider. Google is the
# quickest to set up; Microsoft Entra is the likely fit for Accela.
# ---------------------------------------------------------------------------
# [auth]
# redirect_uri = "https://YOUR-APP.streamlit.app/oauth2callback"
# cookie_secret = "replace-with-a-long-random-string"
# client_id = "YOUR_OAUTH_CLIENT_ID"
# client_secret = "YOUR_OAUTH_CLIENT_SECRET"
#
# For Google:
# server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
#
# For Microsoft Entra (replace TENANT_ID with your Accela tenant):
# server_metadata_url = "https://login.microsoftonline.com/TENANT_ID/v2.0/.well-known/openid-configuration"
